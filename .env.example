# ---- BANCO DE DADOS (CSV) ----
DATABASE_URL=link_do_seu_arquivo_csv

# ---- IA (OpenAI) ----
OPENAI_API_KEY=coloque_sua_chave_aqui
OPENAI_MODEL=coloque_o_modelo_openai

# ---- Caminhos de dados ----
RAW_DATA_PATH=data/raw/WB_EDSTATS_WIDEF.csv
PROCESSED_PATH=data/processed/

# ---- Supabase Storage (persistencia dos artefatos) ----
# SUPABASE_KEY = service_role key (backend only, NUNCA no frontend).
SUPABASE_URL=link_da_url_supabase
SUPABASE_KEY=sua_service_role_key_aqui
SUPABASE_BUCKET=artefatos

# ---- Parametros globais (OPCIONAIS) ----
# ATENCAO: estes sao CODIGOS reais separados por virgula, NAO rotulos/descricoes.
# Um indicador_codigo real tem o formato do World Bank EdStats, por exemplo:
#   WB_EDSTATS_UIS_SLE_1_GPI, WB_EDSTATS_UIS_YR_ST_01T5
# Um pais_codigo real e o ISO-3 em MAIUSCULAS, por exemplo: BRA, USA, PRT
# Deixe VAZIO para processar todos os paises / todos os indicadores.
DEFAULT_COUNTRIES=
DEFAULT_INDICATORS=