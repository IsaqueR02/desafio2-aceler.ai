# ---- IA (OpenAI) ----
OPENAI_API_KEY=coloque-sua-chave-aqui
OPENAI_MODEL=gpt-4o-mini

# ---- E-mail (SMTP) ----
# Para Gmail use uma "Senha de app" (App Password), não a senha normal da conta.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app
EMAIL_REMETENTE=seu-email@gmail.com
EMAIL_DESTINATARIOS=coordenacao@escola.com,diretor@escola.com

# ---- Regras de negócio (opcionais) ----
NOTA_MINIMA_APROVACAO=6.0
FREQUENCIA_MINIMA=75.0
