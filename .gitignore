# ==============================================================
#  .gitignore — Agente Inteligente de Monitoramento Educacional
# ==============================================================

# ---- Segredos / credenciais (NUNCA versionar) ----
.env
.env.local
*.key
*.pem
secrets.json

# ---- Dados (datasets grandes e/ou sensíveis) ----
# Mantém a estrutura das pastas, mas ignora o conteúdo.
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# ---- Saídas geradas (relatórios/gráficos) ----
reports/*
!reports/.gitkeep

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ---- Ambientes virtuais ----
.venv/
venv/
env/
ENV/

# ---- Testes / cobertura / cache ----
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/

# ---- IDEs / editores ----
.vscode/
.idea/
*.swp
*~

# ---- Sistema operacional ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Jupyter ----
.ipynb_checkpoints/
